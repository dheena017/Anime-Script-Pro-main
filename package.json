{
  "name": "creator-studio-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "studio": "concurrently \"npm run dev\" \"npm run backend\"",
    "backend": ".\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.fastapi_app:app --port 8002 --reload",
    "setup:backend": "cd backend && python -m venv venv && .\\venv\\Scripts\\activate && pip install -r requirements.txt",
    "db:seed": "python backend/seed_all.py",
    "db:reset": "rm backend/anime_script_pro.db && npm run db:seed",
    "build": "vite build && esbuild server.ts --platform=node --outfile=dist/server.cjs --format=cjs --bundle --external:pg --external:express",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "start": "node dist/server.cjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-label": "^2.1.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.100.8",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.24.2",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "groq-sdk": "^1.1.2",
    "http-proxy-middleware": "^3.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "motion": "^12.23.24",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0"
  }
}
